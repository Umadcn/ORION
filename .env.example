# =====================================================================
# PROJECT ORION - Example environment configuration
# =====================================================================
# This file contains NO secrets. Copy to backend/.env only if you want
# to override defaults. The project runs fully OFFLINE with defaults.
# NEVER put credentials, company info, internal URLs, or proxy settings here.
# =====================================================================

# Backend server (bound to loopback only for company-laptop safety)
ORION_HOST=127.0.0.1
ORION_PORT=8000

# Integration mode. OFFLINE_FIXTURE (default) uses bundled sample data.
# LIVE_API would attempt real external calls and is DISABLED by default.
# Do NOT enable live mode without explicit network authorization.
ORION_INTEGRATION_MODE=OFFLINE_FIXTURE

# Simulation telemetry generation interval (milliseconds)
ORION_TICK_MS=2000

# Frontend dev server talks to backend via this base URL
VITE_API_BASE_URL=http://127.0.0.1:8000

# =====================================================================
# LLM foundation (Phase 1) — OPTIONAL and OFF by default.
# With none of these set, ORION runs in DETERMINISTIC_FALLBACK mode and
# startup/tests/existing workflows are unaffected. NEVER commit real keys.
# =====================================================================
# Provider: none (default) | openai | anthropic | http (OpenAI-compatible)
ORION_LLM_PROVIDER=none
# Chat-completions endpoint (e.g. https://api.openai.com/v1/chat/completions)
ORION_LLM_ENDPOINT=
# API key — supply via a real secret store / local untracked .env, never here
ORION_LLM_API_KEY=
# Model id (e.g. gpt-4o-mini, claude-3-5-sonnet, etc.)
ORION_LLM_MODEL=
# Per-call timeout, retry, and token budgets
ORION_LLM_TIMEOUT_MS=20000
ORION_LLM_MAX_RETRIES=2
ORION_LLM_MAX_INPUT_TOKENS=6000
ORION_LLM_MAX_OUTPUT_TOKENS=1024
# Deterministic offline fallback (recommended true so the platform never hard-fails)
ORION_LLM_FALLBACK_ENABLED=true

# =====================================================================
# Mission Knowledge Base + Embeddings (Phase 2) — OFFLINE by default.
# With none of these set, ORION uses the in-process LocalHashEmbedding
# provider (deterministic lexical feature hashing — NOT a neural model)
# and requires NO network for ingestion, embedding, or retrieval.
# NEVER commit real keys.
# =====================================================================
# Embedding provider: local (default) | http | openai | none
ORION_EMBEDDING_PROVIDER=local
# Embeddings endpoint (only for a real provider, e.g. https://api.openai.com/v1/embeddings)
ORION_EMBEDDING_ENDPOINT=
# API key — supply via a real secret store / local untracked .env, never here
ORION_EMBEDDING_API_KEY=
# Model id (e.g. text-embedding-3-small) — only for a real provider
ORION_EMBEDDING_MODEL=
# Vector dimension (must match the provider; LocalHashEmbedding uses this too)
ORION_EMBEDDING_DIMENSION=256
# Real-provider per-call timeout and max batch size
ORION_EMBEDDING_TIMEOUT_MS=20000
ORION_EMBEDDING_MAX_BATCH_SIZE=64

# Knowledge ingestion + chunking bounds
ORION_KNOWLEDGE_MAX_DOCUMENT_CHARS=100000
ORION_KNOWLEDGE_MAX_BATCH_DOCUMENTS=25
ORION_KNOWLEDGE_CHUNK_SIZE=1200
ORION_KNOWLEDGE_CHUNK_OVERLAP=150

# Vector retrieval bounds
ORION_RETRIEVAL_DEFAULT_TOP_K=5
ORION_RETRIEVAL_MAX_TOP_K=25
ORION_RETRIEVAL_MAX_CANDIDATES=5000
ORION_RETRIEVAL_MAX_QUERY_CHARS=2000

# =====================================================================
# Hybrid retrieval (Phase 3) — offline + deterministic. BM25 + vector
# fusion via Reciprocal Rank Fusion + optional deterministic reranking.
# No network / no real embedding provider required.
# =====================================================================
# Default retrieval mode when a request omits `mode`:
#   VECTOR (default) | LEXICAL_BM25 | HYBRID_RRF | HYBRID_RRF_RERANK
ORION_RETRIEVAL_DEFAULT_MODE=VECTOR
# Candidate pool sizes fed into fusion (bounded)
ORION_RETRIEVAL_VECTOR_CANDIDATES=50
ORION_RETRIEVAL_BM25_CANDIDATES=50
# Reciprocal Rank Fusion constant k (RRF(d) = Σ 1/(k + rank))
ORION_RETRIEVAL_FUSION_K=60
# Max fused candidates handed to the deterministic reranker
ORION_RETRIEVAL_RERANK_CANDIDATES=50
# BM25 parameters
ORION_RETRIEVAL_BM25_K1=1.2
ORION_RETRIEVAL_BM25_B=0.75
# Bounded query token count for BM25/rerank tokenization
ORION_RETRIEVAL_MAX_QUERY_TOKENS=64
# Max benchmark queries per evaluation run
ORION_RETRIEVAL_EVAL_MAX_QUERIES=50

# =====================================================================
# Grounded generation (Phase 4) — retrieval-augmented investigation
# briefing. Offline + deterministic by default. The LLM is OPTIONAL: with
# no real provider, briefings use the deterministic fallback and are
# labeled DETERMINISTIC_FALLBACK_ACCEPTED (never as real LLM output).
# =====================================================================
# Bounded grounding-context construction
ORION_GENERATION_MAX_CONTEXT_CHARS=8000
ORION_GENERATION_MAX_EVIDENCE_ITEMS=8
ORION_GENERATION_MAX_RETRIEVAL_CHUNKS=6
ORION_GENERATION_MAX_TEXT_PER_SOURCE=600
# Deterministic retrieval for briefings (within Phase 3 bounds)
ORION_GENERATION_RETRIEVAL_TOP_K=5
ORION_GENERATION_MIN_RETRIEVAL_CHUNKS=1
# Claim-level grounding: minimum lexical support (0..1). NOT a confidence.
ORION_GENERATION_MIN_GROUNDING_SUPPORT=0.5
# Bounded generated arrays
ORION_GENERATION_MAX_CLAIMS=12
# Prompt-injection filtering of retrieved (untrusted) chunks
ORION_GENERATION_INJECTION_FILTER_ENABLED=true

# =====================================================================
# Mission Copilot (Phase 5) — READ-ONLY conversational RAG + controlled,
# allowlisted read-only tool calling. Offline + deterministic by default
# (deterministic intent-routed planner over the same tool registry when
# no real LLM provider is configured). All limits are bounded.
# =====================================================================
ORION_COPILOT_MAX_ITERATIONS=4
ORION_COPILOT_MAX_TOOL_CALLS=6
ORION_COPILOT_MAX_TOOL_OUTPUT_CHARS=4000
ORION_COPILOT_MAX_MESSAGE_CHARS=2000
ORION_COPILOT_MAX_CONTEXT_CHARS=8000
ORION_COPILOT_MAX_RETAINED_MESSAGES=20
ORION_COPILOT_MAX_EXECUTION_MS=15000
ORION_COPILOT_TOOL_TIMEOUT_MS=3000
ORION_COPILOT_MAX_SUGGESTED_FOLLOWUPS=4

# =====================================================================
# ORION AI Assistant (Phase 10) — the Copilot upgraded into a full
# read-only agentic assistant. All bounds are safe offline defaults;
# startup is unaffected when unset. Real-provider behavior is opt-in
# (configure a provider via the Phase 1/9 provider variables). NO
# credentials belong here — the Assistant never accepts provider/model/
# endpoint/tool/capability overrides.
# =====================================================================
ORION_ASSISTANT_MAX_MESSAGE_CHARS=2000
ORION_ASSISTANT_MAX_CONTEXT_CHARS=8000
ORION_ASSISTANT_MAX_RETAINED_MESSAGES=16
ORION_ASSISTANT_MAX_SUMMARY_CHARS=1200
ORION_ASSISTANT_MAX_ITERATIONS=5
ORION_ASSISTANT_MAX_TOOL_CALLS=8
ORION_ASSISTANT_MAX_RETRIEVAL_CALLS=3
ORION_ASSISTANT_MAX_WORKFLOW_CALLS=2
ORION_ASSISTANT_MAX_EXECUTION_MS=30000
ORION_ASSISTANT_TOOL_TIMEOUT_MS=4000
ORION_ASSISTANT_MAX_EVENTS=200
ORION_ASSISTANT_MAX_RICH_CONTENT_ITEMS=6
ORION_ASSISTANT_MAX_SUGGESTED_FOLLOWUPS=4
ORION_ASSISTANT_MAX_FEEDBACK_COMMENT_CHARS=500
ORION_ASSISTANT_EVAL_MAX_SCENARIOS=15
# Advisory governance thresholds (surfaced, never enforced).
ORION_ASSISTANT_GOV_FALLBACK_RATE_MAX=0.5
ORION_ASSISTANT_GOV_FAILURE_RATE_MAX=0.2
ORION_ASSISTANT_GOV_INSUFFICIENT_RATE_MAX=0.4
ORION_ASSISTANT_GOV_GROUNDING_VALID_RATE_MIN=0.8
ORION_ASSISTANT_GOV_TOOL_ERROR_RATE_MAX=0.2
ORION_ASSISTANT_GOV_NEGATIVE_FEEDBACK_RATE_MAX=0.5
ORION_ASSISTANT_GOV_REAL_REJECTION_RATE_MAX=0.5

# =====================================================================
# Bounded Planner Agent + Agentic RAG (Phase 6) — READ-ONLY analysis
# assistance. Deterministic offline planner by default; every loop/step/
# retrieval is bounded. Never mutates mission state.
# =====================================================================
ORION_PLANNER_MAX_STEPS=10
ORION_PLANNER_MAX_ITERATIONS=12
ORION_PLANNER_MAX_TOOL_CALLS=16
ORION_PLANNER_MAX_RETRIEVAL_CALLS=3
ORION_PLANNER_MAX_QUERY_REFINEMENTS=2
ORION_PLANNER_MAX_OUTPUT_CHARS=12000
ORION_PLANNER_MAX_EXECUTION_MS=20000
ORION_PLANNER_STEP_TIMEOUT_MS=4000
ORION_PLANNER_MIN_CITATIONS=1
ORION_PLANNER_MIN_EVIDENCE_ITEMS=1

# =====================================================================
# Bounded Critic Agent + Reflection/Revision loop (Phase 7). READ-ONLY
# analysis-quality review of a Planner analysis before human review.
# Deterministic offline Critic by default; the reflection loop is strictly
# bounded. ACCEPT is not mission approval; REJECT is not investigation
# rejection. Never mutates mission state; the deterministic RCA is authoritative.
# =====================================================================
ORION_CRITIC_MAX_ISSUES=20
ORION_CRITIC_MAX_REVISION_ATTEMPTS=2
ORION_CRITIC_MAX_CALLS=6
ORION_CRITIC_MAX_CONTEXT_CHARS=12000
ORION_CRITIC_MAX_EXECUTION_MS=20000
ORION_CRITIC_MIN_COVERAGE_ITEMS=6
ORION_CRITIC_NUMERIC_TOLERANCE=0.05

# =====================================================================
# Read-only AI Observability, Evaluation & Governance (Phase 8).
# Aggregates the EXISTING audit tables; strictly read-only. Director/Admin
# only. Governance thresholds are ADVISORY — they never mutate anything.
# =====================================================================
ORION_OBSERVABILITY_DEFAULT_RANGE=7D
ORION_OBSERVABILITY_MAX_RANGE_DAYS=30
ORION_OBSERVABILITY_MAX_ROWS=100000
ORION_OBSERVABILITY_TIMESERIES_BUCKET_LIMIT=48
ORION_OBSERVABILITY_MAX_DISTRIBUTION_ITEMS=12
ORION_OBSERVABILITY_MAX_EVALUATION_HISTORY=25
# Governance thresholds (advisory):
ORION_OBSERVABILITY_GOV_LLM_FALLBACK_RATE_MAX=0.5
ORION_OBSERVABILITY_GOV_LLM_FAILURE_RATE_MAX=0.2
ORION_OBSERVABILITY_GOV_STRUCTURED_VALID_RATE_MIN=0.8
ORION_OBSERVABILITY_GOV_GROUNDING_REJECTION_RATE_MAX=0.5
ORION_OBSERVABILITY_GOV_CITATION_VALID_RATE_MIN=0.8
ORION_OBSERVABILITY_GOV_RETRIEVAL_ZERO_RESULT_RATE_MAX=0.5
ORION_OBSERVABILITY_GOV_COPILOT_TOOL_ERROR_RATE_MAX=0.2
ORION_OBSERVABILITY_GOV_PLANNER_FAILURE_RATE_MAX=0.5
ORION_OBSERVABILITY_GOV_CRITIC_CONTRADICTION_AVG_MAX=1
ORION_OBSERVABILITY_GOV_REVISION_LIMIT_RATE_MAX=0.5

# =====================================================================
# Real-provider GenAI + semantic embeddings (Phase 9). ALL real-provider
# functionality is OPT-IN. With none of the ORION_LLM_*/ORION_EMBEDDING_*
# credentials set, ORION runs fully offline (DETERMINISTIC_FALLBACK LLM +
# LOCAL_HASH_FALLBACK embeddings). NEVER put real credentials in this file —
# configure them in a local, git-ignored .env only.
#
# To enable a REAL LLM provider (OpenAI-compatible chat completions):
#   ORION_LLM_PROVIDER=openai
#   ORION_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
#   ORION_LLM_API_KEY=__set_locally_only__
#   ORION_LLM_MODEL=gpt-4o-mini
# To enable a REAL embedding provider (OpenAI-compatible embeddings):
#   ORION_EMBEDDING_PROVIDER=openai
#   ORION_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
#   ORION_EMBEDDING_API_KEY=__set_locally_only__
#   ORION_EMBEDDING_MODEL=text-embedding-3-small
#   ORION_EMBEDDING_DIMENSION=1536
#
# Provider allowlists (config, never inferred from a name):
ORION_LLM_PROVIDER_ALLOWLIST=openai,azure-openai,anthropic,http
ORION_EMBEDDING_PROVIDER_ALLOWLIST=openai,azure-openai,http
# Require HTTPS for any non-loopback provider endpoint:
ORION_PROVIDER_REQUIRE_HTTPS=true
# Explicit LLM capability declarations (never inferred):
ORION_LLM_SUPPORTS_STRUCTURED_OUTPUT=true
ORION_LLM_SUPPORTS_JSON_SCHEMA=false
ORION_LLM_SUPPORTS_TOOL_CALLING=false
ORION_LLM_SUPPORTS_STREAMING=false
# Embedding normalization policy:
ORION_EMBEDDING_NORMALIZED=true
# Verification / re-embedding / comparison bounds:
ORION_PROVIDER_VERIFY_COOLDOWN_MS=15000
ORION_PROVIDER_VERIFY_TIMEOUT_MS=20000
ORION_PROVIDER_VERIFY_STALE_MS=86400000
ORION_EMBEDDING_REINDEX_BATCH_SIZE=16
ORION_PROVIDER_COMPARISON_MAX_SCENARIOS=12
ORION_PROVIDER_COMPARISON_COOLDOWN_MS=30000
